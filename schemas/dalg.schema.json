{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://layerforge.dev/schemas/dalg.schema.json",
  "title": "LayerForge Depth-Aware Amodal Layer Graph",
  "type": "object",
  "required": [
    "$schema",
    "kind",
    "schema_version",
    "dalg_version",
    "alpha_mode",
    "color_space",
    "input_hash",
    "model_manifest",
    "creation_time",
    "config_hash",
    "canvas",
    "asset",
    "recipe",
    "graph",
    "layers",
    "metrics",
    "exports"
  ],
  "properties": {
    "$schema": {
      "const": "https://layerforge.dev/schemas/dalg.schema.json"
    },
    "kind": {
      "const": "layerforge.dalg"
    },
    "schema_version": {
      "type": "string"
    },
    "dalg_version": {
      "type": "string",
      "enum": [
        "1.0",
        "1.1"
      ]
    },
    "alpha_mode": {
      "type": "string",
      "enum": [
        "straight",
        "premultiplied"
      ]
    },
    "color_space": {
      "type": "string"
    },
    "input_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "model_manifest": {
      "type": "object",
      "additionalProperties": true
    },
    "creation_time": {
      "type": "string"
    },
    "config_hash": {
      "type": "string"
    },
    "canvas": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "width",
        "height"
      ],
      "additionalProperties": false
    },
    "asset": {
      "type": "object",
      "required": [
        "input",
        "run_dir",
        "mode"
      ],
      "properties": {
        "input": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_dir": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "recipe": {
      "type": "object",
      "properties": {
        "segmentation_method": {
          "type": [
            "string",
            "null"
          ]
        },
        "depth_method": {
          "type": [
            "string",
            "null"
          ]
        },
        "depth_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "ordering_method": {
          "type": [
            "string",
            "null"
          ]
        },
        "visual_order_mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_external_visual_order": {
          "type": [
            "string",
            "null"
          ]
        },
        "intrinsic_method": {
          "type": [
            "string",
            "null"
          ]
        },
        "inpaint_method": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "graph": {
      "type": "object",
      "required": [
        "ordering",
        "graph_order_available",
        "node_count",
        "edge_count",
        "layers",
        "edges"
      ],
      "properties": {
        "ordering": {
          "const": "near_to_far"
        },
        "graph_order_available": {
          "type": "boolean"
        },
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "layers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/layer"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        }
      },
      "additionalProperties": true
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "rank",
          "group",
          "depth_median",
          "editable"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "rank": {
            "type": "integer",
            "minimum": 0
          },
          "group": {
            "type": "string"
          },
          "bbox": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "integer"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "depth_median": {
            "type": [
              "number",
              "null"
            ]
          },
          "editable": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "exports": {
      "type": "object",
      "required": [
        "source_manifest",
        "metrics",
        "grouped_layers",
        "effect_layers",
        "debug"
      ],
      "properties": {
        "source_manifest": {
          "type": "string"
        },
        "metrics": {
          "type": [
            "string",
            "null"
          ]
        },
        "grouped_layers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "effect_layers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "debug": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "layer": {
      "type": "object",
      "required": [
        "id",
        "name",
        "label",
        "group",
        "rank",
        "editable",
        "paths",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "name": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "rank": {
          "type": "integer",
          "minimum": 0
        },
        "editable": {
          "type": "boolean"
        },
        "bbox": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "integer"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "area": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "depth_median": {
          "type": [
            "number",
            "null"
          ]
        },
        "occludes": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "occluded_by": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "paths": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "visible_mask_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "amodal_mask_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "hidden_mask_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "rgba_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "completed_rgba_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "albedo_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "shading_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "alpha_confidence_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "depth_stats": {
          "type": "object",
          "additionalProperties": true
        },
        "semantic_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_backend": {
          "type": [
            "string",
            "null"
          ]
        },
        "provenance": {
          "type": "object",
          "additionalProperties": true
        },
        "quality_metrics": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": [
        "near_id",
        "far_id",
        "confidence"
      ],
      "properties": {
        "near_id": {
          "type": "integer"
        },
        "far_id": {
          "type": "integer"
        },
        "confidence": {
          "type": "number"
        },
        "shared_boundary_length": {
          "type": [
            "integer",
            "null"
          ]
        },
        "local_depth_gap": {
          "type": [
            "number",
            "null"
          ]
        },
        "near_local_depth": {
          "type": [
            "number",
            "null"
          ]
        },
        "far_local_depth": {
          "type": [
            "number",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "relation": {
          "type": "string",
          "enum": [
            "in_front_of",
            "behind",
            "same_plane",
            "uncertain"
          ]
        },
        "evidence": {
          "type": "object",
          "properties": {
            "boundary_depth_delta": {
              "type": [
                "number",
                "null"
              ]
            },
            "overlap_ratio": {
              "type": [
                "number",
                "null"
              ]
            },
            "contact_score": {
              "type": [
                "number",
                "integer",
                "null"
              ]
            },
            "semantic_prior": {
              "type": [
                "number",
                "null"
              ]
            },
            "model_confidence": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "conflict_notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
